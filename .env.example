# Ollama 서버 주소입니다.
# 보통 Ollama를 내 컴퓨터에서 실행하면 아래 주소를 그대로 사용합니다.
OLLAMA_HOST=http://localhost:11434

# 답변을 생성할 Ollama LLM 모델입니다.
LLM_MODEL=gemma3:4b

# 문서를 숫자 벡터로 바꿀 Ollama 임베딩 모델입니다.
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB 데이터가 저장될 폴더입니다.
CHROMA_DB_DIR=./chroma_db

# TXT 문서가 들어 있는 폴더입니다.
TXT_DATA_DIR=./data/txt

# PDF 문서가 들어 있는 폴더입니다.
PDF_DATA_DIR=./data/pdf

# TXT 파일 전용 청크 설정입니다.
TXT_CHUNK_SIZE=700
TXT_CHUNK_OVERLAP=100

# PDF 파일 전용 청크 설정입니다.
PDF_CHUNK_SIZE=1000
PDF_CHUNK_OVERLAP=150
